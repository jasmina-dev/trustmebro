# ---------------------------------------------------------------------------
# PMXT — unified prediction market API (https://pmxt.dev)
# Get a key at https://pmxt.dev/dashboard — starts with pmxt_live_
# ---------------------------------------------------------------------------
PMXT_API_KEY=pmxt_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cap Router requests per minute per Node process (PMXT free tier = 60/min).
# Default in code is 50. Raise if your PMXT plan allows more RPM.
# PMXT_ROUTER_MAX_PER_MINUTE=50

# ---------------------------------------------------------------------------
# Upstash Redis — serverless cache (https://console.upstash.com)
# Used for: rate limiting + per-route response caching (shared across users).
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cool live slices longer so concurrent users hit Redis more often (seconds).
# MARKETS_LIVE_TTL_SECONDS=120
# RAW_PAGE_LIVE_TTL_SECONDS=120

# When Upstash is enabled: one Node repopulates each cache key; others wait (default on).
# UPSTASH_COORDINATE_MISS=false
# CACHE_COORD_LOCK_SECONDS=600
# CACHE_COORD_WAIT_MS=240000

# ---------------------------------------------------------------------------
# Anthropic — chatbot model backend (claude-sonnet-latest)
# Get a key at https://console.anthropic.com
# Required in production: add the same variable in your host (e.g. Vercel
# Project Settings → Environment Variables) for Production and redeploy.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional — Anthropic Messages API model id (must match your key / account).
# Default in code: claude-3-5-sonnet-20241022 (pinned; -latest alias was retired)
# Recommended upgrade: claude-4-sonnet-20250514
# Do not use un-dated alias ids like claude-3-5-sonnet-latest (will fail).
# ---------------------------------------------------------------------------
# ANTHROPIC_MODEL=claude-4-sonnet-20250514

# ---------------------------------------------------------------------------
# Optional — chat rate limiting (defaults: 20 requests / 60 seconds / IP)
# ---------------------------------------------------------------------------
# CHAT_RATE_LIMIT_MAX=20
# CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Optional — override archive endpoint. Defaults to https://archive.pmxt.dev/
# ---------------------------------------------------------------------------
# PMXT_ARCHIVE_URL=https://archive.pmxt.dev/

# ---------------------------------------------------------------------------
# Internal API protection (production / Vercel)
# CRON_SECRET — random string; add the same value in Vercel project env so cron
#               jobs send Authorization: Bearer <CRON_SECRET> to /api/warmup.
# ---------------------------------------------------------------------------
# CRON_SECRET=
